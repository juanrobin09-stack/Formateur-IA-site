# =============================================================================
# Formator AI — Variables d'environnement
# Copiez ce fichier en `.env.local` et renseignez vos valeurs.
# IMPORTANT : le site BUILD et FONCTIONNE même si ces variables sont absentes
# (les fonctionnalités concernées s'affichent alors dans un état désactivé élégant).
# =============================================================================

# --- URL publique du site (utilisée pour le SEO / Open Graph / sitemap) ------
NEXT_PUBLIC_SITE_URL=https://formator-ai.fr

# --- Resend : envoi des emails du formulaire de contact ----------------------
# https://resend.com — créez une clé API. Sans cette clé, les messages sont
# simplement journalisés côté serveur et l'utilisateur reçoit un message de succès.
RESEND_API_KEY=
# Adresse expéditrice vérifiée chez Resend (ex. contact@votre-domaine.fr)
CONTACT_FROM_EMAIL=onboarding@resend.dev
# Adresse qui reçoit les demandes de contact
CONTACT_TO_EMAIL=juanrobin89@gmail.com

# --- Informations facultatives (mentions légales / réseaux) ------------------
# Renseignez-les pour enrichir le site ; sinon les éléments concernés sont masqués.
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_SIRET=
NEXT_PUBLIC_ADDRESS=

# --- Calendly : prise de rendez-vous -----------------------------------------
# Collez l'URL de votre page Calendly (ex. https://calendly.com/votre-compte/audit)
NEXT_PUBLIC_CALENDLY_URL=
